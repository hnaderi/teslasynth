CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=240
CONFIG_ESP32S2_DEFAULT_CPU_FREQ_240=y
CONFIG_ESP32S2_DEFAULT_CPU_FREQ_MHZ=240

CONFIG_TINYUSB_MIDI_COUNT=1

CONFIG_TESLASYNTH_OUTPUT_GPIO_PIN1=1
CONFIG_TESLASYNTH_OUTPUT_GPIO_PIN2=2
CONFIG_TESLASYNTH_OUTPUT_GPIO_PIN3=3
CONFIG_TESLASYNTH_OUTPUT_GPIO_PIN4=4

CONFIG_ESP_CONSOLE_UART_CUSTOM=y
CONFIG_ESP_CONSOLE_UART=y
CONFIG_ESP_CONSOLE_UART_CUSTOM_NUM_0=y
CONFIG_ESP_CONSOLE_UART_NUM=0
CONFIG_ESP_CONSOLE_ROM_SERIAL_PORT_NUM=0
CONFIG_ESP_CONSOLE_UART_TX_GPIO=37
CONFIG_ESP_CONSOLE_UART_RX_GPIO=38
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200

# WPA3 SAE password-element derivation hogs CPU 0 long enough to starve
# IDLE on this single-core target and trip the 1 s TWDT. Drop SAE on S2
# only; the AP falls back to WPA2-PSK via the #ifdef in wifi.cpp.
CONFIG_ESP_WIFI_SOFTAP_SAE_SUPPORT=n
