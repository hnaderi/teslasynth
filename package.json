{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.0",
  "author": "Hossein Naderi <hossein-naderi@hotmail.com>",
  "scripts": {
    "build": "pnpm -r build",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "dev:site": "pnpm --filter site dev",
    "build:dashboard": "pnpm --filter dashboard build",
    "build:site": "pnpm --filter site build",
    "test": "pnpm -r --if-present test",
    "lint": "eslint 'web/**/*.{js,jsx,ts,tsx}'",
    "format": "prettier --write 'web/**/*.{js,jsx,ts,tsx,css,scss}'",
    "format:check": "prettier --check 'web/**/*.{js,jsx,ts,tsx,css,scss}'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.58.2"
  }
}
